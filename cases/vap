<!-- DIAGNOSTIC GUIDE MODAL                                -->

<!-- ===================================================== -->

<div id="guideModal" class="modal">

```
<div class="modal-content">

    <span class="close">&times;</span>

    <h2>BIOL 334 Unknown Identification Guide</h2>

    <ol>

        <li>
            Perform a Gram Stain
            <ul>
                <li>Gram-positive cocci → Step 2</li>
                <li>Gram-positive rods → Step 5</li>
                <li>Gram-negative rods → Step 6</li>
            </ul>
        </li>

        <li>
            Catalase Test
            <ul>
                <li>Catalase positive → Step 3</li>
                <li>Catalase negative → Step 4</li>
            </ul>
        </li>

        <li>
            Coagulase Test
            <ul>
                <li>Positive → Staphylococcus aureus</li>
                <li>Negative → Staphylococcus epidermidis</li>
            </ul>
        </li>

        <li>
            Blood Agar
            <ul>
                <li>Alpha hemolytic → Viridans streptococci</li>
            </ul>
        </li>

        <li>
            Endospore Stain
            <ul>
                <li>Positive → Bacillus cereus</li>
            </ul>
        </li>

        <li>
            MacConkey Agar
            <ul>
                <li>Pink colonies → Step 7</li>
                <li>Colorless colonies → Step 8</li>
            </ul>
        </li>

        <li>
            Lactose Fermenters
            <ul>
                <li>Indole positive → Escherichia coli</li>
                <li>Sorbitol negative → E. coli O157:H7</li>
                <li>Citrate positive → Klebsiella aerogenes</li>
            </ul>
        </li>

        <li>
            Non-Lactose Fermenters
            <ul>
                <li>Oxidase positive → Pseudomonas aeruginosa</li>
                <li>Urease positive → Proteus mirabilis</li>
            </ul>
        </li>

    </ol>

</div>
```

