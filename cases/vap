<div class="patient-banner">
    <h3>Barbara Iglewski</h3>
    <p>56-year-old patient</p>

    <p>
        <strong>Chief Concern:</strong>
        Fever and worsening respiratory status while on a ventilator.
    </p>
</div>

<h3>Patient Background</h3>

<p>
Barbara remains intubated following abdominal surgery and develops pneumonia
after seven days in the ICU.
</p>

<h3>Clinical Findings</h3>

<table>
<tr><th>Finding</th><th>Result</th></tr>
<tr><td>Temperature</td><td>102.4°F</td></tr>
<tr><td>Respiratory Rate</td><td>30 breaths/min</td></tr>
<tr><td>O₂ Saturation</td><td>84%</td></tr>
<tr><td>Chest X-ray</td><td>Diffuse infiltrates</td></tr>
<tr><td>WBC Count</td><td>17,800 /µL</td></tr>
</table>

<h3>Available Sample</h3>
<div class="sample-box">Endotracheal Aspirate</div>

<!-- ===================================================== -->
<!-- STOP REPLACE PATIENT INFORMATION                      -->
<!-- ===================================================== -->

<section class="card">

    <button id="guideBtn" class="guide-btn">
        🔬 Open Diagnostic Guide
    </button>

</section>

<section class="card">

    <h2>Order Diagnostic Tests</h2>

    <div class="counter">
        Tests Ordered:
        <span id="test-count">0</span>
    </div>

    <div class="test-grid">

        <button onclick="orderTest('gram')">Gram Stain</button>

        <button onclick="orderTest('bloodAgar')">Blood Agar</button>

        <button onclick="orderTest('catalase')">Catalase</button>

        <button onclick="orderTest('coagulase')">Coagulase</button>

        <button onclick="orderTest('endospore')">Endospore Stain</button>

        <button onclick="orderTest('macconkey')">MacConkey Agar</button>

        <button onclick="orderTest('indole')">Indole Test</button>

        <button onclick="orderTest('citrate')">Citrate Test</button>

        <button onclick="orderTest('oxidase')">Oxidase Test</button>

        <button onclick="orderTest('urease')">Urease Test</button>

        <button onclick="orderTest('smac')">Sorbitol MacConkey</button>

        <button onclick="orderTest('kirby')">Kirby-Bauer</button>

    </div>

</section>

<section class="card">

    <h2>Results</h2>

    <div id="results-box">
        No tests ordered yet.
    </div>

</section>

<section class="card">

    <h2>Final Diagnosis</h2>

    <label>
        Most Likely Organism
    </label>

    <input
        type="text"
        id="diagnosis"
        placeholder="Enter organism name">

    <label>
        Antibiotic Recommendation
    </label>

    <input
        type="text"
        id="treatment"
        placeholder="Enter antibiotic">

    <button onclick="checkDiagnosis()">
        Submit Diagnosis
    </button>

    <div id="feedback"></div>

</section>
```

</main>

